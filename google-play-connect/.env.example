PORT=8080
BASE_URL=http://localhost:8080

# Google OAuth web client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Cloud project used for the Play service account.
GOOGLE_CLOUD_PROJECT_ID=
SERVICE_ACCOUNT_ID=zeywin-play-publisher
SERVICE_ACCOUNT_DISPLAY_NAME=ZeyWin Google Play Publisher

# GitHub repository that receives GOOGLE_PLAY_SERVICE_ACCOUNT_JSON.
GITHUB_OWNER=zey-win
GITHUB_REPO=ci-cd
GITHUB_TOKEN=
GITHUB_SECRET_NAME=GOOGLE_PLAY_SERVICE_ACCOUNT_JSON

# Optional comma-separated allowlist for Google accounts that can run setup.
ALLOWED_GOOGLE_EMAILS=

