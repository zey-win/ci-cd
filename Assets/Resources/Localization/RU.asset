      \u0438 \u0432\u0432\u0435\u0434\u0451\u043D \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E"
  - key: crypto_number_correct
    value: "\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u0441\u044C,
      \u0447\u0442\u043E \u0432\u0430\u0448 \u043A\u0440\u0438\u043F\u0442\u043E
      \u0430\u0434\u0440\u0435\u0441 \u0434\u043E\u0441\u0442\u0443\u043F\u0435\u043D
      \u0438 \u0432\u0432\u0435\u0434\u0451\u043D \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E"
  - key: paypal_number_correct
    value: "\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u0441\u044C,
      \u0447\u0442\u043E \u0432\u0430\u0448 \u0430\u043A\u043A\u0430\u0443\u043D\u0442
