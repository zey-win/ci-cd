    value: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E!"
  - key: are_you_sure_you_want_to_delete_payment
    value: "\u0412\u044B \u0443\u0432\u0435\u0440\u0435\u043D\u044B, \u0447\u0442\u043E
