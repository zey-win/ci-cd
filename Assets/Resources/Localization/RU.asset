    value: "\u041F\u043B\u0430\u0442\u0451\u0436 \u043E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442\u0441\u044F"
  - key: within_24_hours_the_payment_will_be_sent
    value: "\u0412 \u0442\u0435\u0447\u0435\u043D\u0438\u0435 24 \u0447\u0430\u0441\u043E\u0432
