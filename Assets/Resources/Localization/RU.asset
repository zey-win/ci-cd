  - key: wallet_collect_coins_desc
    value: "\u0415\u0441\u043B\u0438 \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435
      \u043C\u043E\u043D\u0435\u0442\u044B \u0434\u043E\u0441\u0442\u0438\u0433\u043D\u0443\u0442
      \u0446\u0435\u043B\u0438 \u0434\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F
      \u0442\u0430\u0439\u043C\u0435\u0440\u0430, \L\u043C\u043E\u043D\u0435\u0442\u044B
      \u0431\u0443\u0434\u0443\u0442 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u044B
      \u0432 \u043D\u0430\u0433\u0440\u0430\u0434\u044B, \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0435
      \u0434\u043B\u044F \u043E\u0431\u043C\u0435\u043D\u0430."
